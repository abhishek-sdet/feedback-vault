// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Submission {
  id          String   @id @default(uuid())
  feedbackId  String   @unique                  // Human-readable ID (e.g., EV-2381)
  category    String                            // Suggestion, Question, Concern, Ethics, Appreciation
  content     String
  isAnonymous Boolean  @default(true)
  senderName  String?                           // Optional if not anonymous
  department  String?
  location    String?
  urgency     String?  @default("NORMAL")       // NORMAL, URGENT, CRITICAL
  status      String   @default("RECEIVED")     // RECEIVED, UNDER_REVIEW, ACTION_TAKEN, CLOSED
  response    String?                           // Internal or public response
  impact      String?                           // Summary for "You Said - We Did"
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model Registry {
  key   String @id
  value String
}
